{
  "manifest_version": 3,
  "name": "comic-walker, ichicomi",
  "version": "2.1.0",
  "description": "Captures active Splide reader canvases by cropping the visible slide from screenshots.",
  "permissions": ["activeTab", "tabs", "downloads", "scripting", "windows"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Splide Reader Capture",
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      }
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["style.css"],
      "matches": ["<all_urls>"]
    }
  ]
}