{
  "manifest_version": 3,
  "name": "PSWP Slideshow Downloader",
  "version": "1.3",
  "description": "Downloads slideshow images one by one by clicking next.",
  "permissions": [
    "downloads",
    "activeTab",
    "scripting",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "commands": {
    "start-download": {
      "suggested_key": {
        "windows": "Ctrl+Shift+U",
        "linux": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Start downloading slideshow images"
    }
  }
}